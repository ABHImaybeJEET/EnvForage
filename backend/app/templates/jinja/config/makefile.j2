# ==============================================================================
# EnvForge Generated Makefile
# Profile : {{ profile.name }}
# OS      : {{ target_os }}
# Python  : {{ python_version }}
{% if cuda_version %}# CUDA    : {{ cuda_version }}
{% endif %}# ==============================================================================

.PHONY: install verify clean help

## install: Set up the full {{ profile.name }} environment
install:
{% if target_os == "WIN" %}
	@echo "[EnvForge] Running Windows setup..."
	powershell -ExecutionPolicy Bypass -File setup.ps1
{% else %}
	@echo "[EnvForge] Running Linux/WSL setup..."
	@bash setup.sh
{% endif %}

## verify: Verify the installed environment
verify:
{% if target_os == "WIN" %}
	@echo "[EnvForge] Verifying environment..."
	powershell -Command "python -c \"import sys; print('Python', sys.version)\""
{% else %}
	@echo "[EnvForge] Verifying environment..."
	@python{{ python_version }} -c "import sys; print('Python', sys.version)"
{% endif %}
{% for pkg in packages %}
	@python{{ python_version }} -c "import {{ pkg.name.split('[')[0].replace('-','_').replace('.','_') }}; print('OK: {{ pkg.name }}')" || echo "MISSING: {{ pkg.name }}"
{% endfor %}

## clean: Remove virtual environment and cached files
clean:
{% if target_os == "WIN" %}
	@echo "[EnvForge] Cleaning environment..."
	@if exist .venv rmdir /s /q .venv
	@if exist __pycache__ rmdir /s /q __pycache__
{% else %}
	@echo "[EnvForge] Cleaning environment..."
	@rm -rf .venv __pycache__ *.pyc .pytest_cache
{% endif %}

## help: Show available make targets
help:
	@echo ""
	@echo "EnvForge — {{ profile.name }} Environment"
	@echo "==========================================="
	@grep -E '^## ' $(MAKEFILE_LIST) | sed 's/## /  /'
	@echo ""
